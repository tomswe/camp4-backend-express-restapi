  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// attach access token otomatis jika ada\r",
          "if (pm.environment.get(\"access_token\")) {\r",
          "  pm.request.headers.add({\r",
          "    key: \"Authorization\",\r",
          "    value: \"Bearer \" + pm.environment.get(\"access_token\"),\r",
          "  });\r",
          "}\r",
          "\r",
          "// fallback refresh token header\r",
          "if (pm.environment.get(\"refresh_token\")) {\r",
          "  pm.request.headers.add({\r",
          "    key: \"x-refresh-token\",\r",
          "    value: pm.environment.get(\"refresh_token\"),\r",
          "  });\r",
          "}"
        ]
      }
    },
