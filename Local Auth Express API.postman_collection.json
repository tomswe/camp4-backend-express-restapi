    {
      "name": "User data",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Get current user\", () => {\r",
              "  pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const res = pm.response.json();\r",
              "\r",
              "pm.expect(res).to.have.property(\"id\");\r",
              "pm.expect(res).to.have.property(\"email\");\r",
              "pm.expect(res).to.have.property(\"role\");\r",
              "\r",
              "// sync env\r",
              "pm.environment.set(\"user_id\", res.id);\r",
              "pm.environment.set(\"user_email\", res.email);\r",
              "pm.environment.set(\"user_role\", res.role);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
